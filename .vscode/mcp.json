{
    "inputs": [
        {
            "type": "promptString",
            "id": "n8n-mcp-token",
            "description": "Your n8n-MCP AUTH_TOKEN",
            "password": true
        }
    ],
    "servers": {
        "n8n-mcp": {
            "type": "http",
            "url": "https://centredudos.app.n8n.cloud/mcp",
            "headers": {
                "Authorization": "Bearer ${input:n8n-mcp-token}"
            }
        }
    }
}
